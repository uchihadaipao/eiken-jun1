    {
      "index": 3,
      "speaker": "★",
      "start": 16560,
      "end": 19380,
      "en": "There are some hotels on the main road.",
      "zh": "主路上有一些酒店。",
      "original_start": 16460,
      "original_end": 19380
    },
    {
      "index": 4,
      "speaker": "★",
      "start": 19480,
      "end": 21260,
      "en": "The Weverton Inn is good.",
      "zh": "韦弗顿酒店很不错。",
      "original_start": 19380,
      "original_end": 21260
    },
    {
      "index": 5,
      "speaker": "★",
      "start": 21360,
      "end": 23140,
      "en": "It has a nice restaurant.",
      "zh": "它有一家很好的餐厅。",
      "original_start": 21260,
      "original_end": 23140
    },
    {
      "index": 6,
      "speaker": "★",
      "start": 23240,
      "end": 28340,
      "en": "There's live music at night, though, which could make putting the kids to bed difficult",
      "zh": "不过晚上有现场音乐，这可能会让哄孩子睡觉变得困难，",
      "original_start": 23140,
