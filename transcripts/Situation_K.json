    },
    {
      "index": 9,
      "speaker": "★",
      "start": 33480,
      "end": 38460,
      "en": "It's next door to the Weverton, but you can't hear the noise from the restaurant.",
      "zh": "它在韦弗顿隔壁，但你听不到餐厅的噪音。",
      "original_start": 33380,
      "original_end": 38460
    },
    {
      "index": 10,
      "speaker": "★",
      "start": 38560,
      "end": 41940,
      "en": "It's too bad the Mountain View Motel closed down recently.",
